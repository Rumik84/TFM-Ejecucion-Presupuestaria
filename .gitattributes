# Fuerza LF en archivos de texto para evitar problemas CRLF en contenedores Linux
*.sh        text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.toml      text eol=lf
*.env*      text eol=lf
Makefile    text eol=lf
